### .env.example

```bash
# ═══════════════════════════════════════════════════════
# Grant Path AI — Environment Configuration
# Copy to .env: cp .env.example .env
# ═══════════════════════════════════════════════════════

# ─── REQUIRED ─────────────────────────────────────────
# Google Gemini API Key (FREE: 1M tokens/day)
# Get at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Database URL
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/grantpath

# JWT Secret (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-64-char-hex-string-in-production

# ─── RECOMMENDED ──────────────────────────────────────
# Groq API Key (FREE: ultra-fast Llama)
# Get at: https://console.groq.com
GROQ_API_KEY=

# Redis URL (for caching & rate limiting)
REDIS_URL=redis://localhost:6379

# ─── OPTIONAL ─────────────────────────────────────────
# OpenAI (PAID: for premium quality writing)
OPENAI_API_KEY=

# ─── APP CONFIG ───────────────────────────────────────
ENV=development
API_PORT=8000
API_HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000
MODEL_SERVICE_URL=http://localhost:8001
DAILY_PREMIUM_TOKEN_BUDGET=50000
LOG_LEVEL=DEBUG
